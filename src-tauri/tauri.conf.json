{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Linear",
  "version": "0.2.3",
  "identifier": "app.linear.linux",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Linear",
        "url": "https://linear.app/login",
        "width": 800,
        "height": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": null
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
